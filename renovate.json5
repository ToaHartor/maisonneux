{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  enabledManagers: [
    "terraform",
    "helm-values",
    "helmv3",
    "flux",
    "github-actions",
    "custom.regex",
    // "pyenv"
    // "mise",
  ], // Only enable comments
  // Group major-minor-patch PRs
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:enableMajor",
    ":semanticCommits",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":automergeDigest",
    // Common presets from https://github.com/home-operations/renovate-presets
    "github>home-operations/renovate-presets//policies/semanticCommits.json5",
  ],
  separateMajorMinor: false,
  separateMultipleMajor: true,
  separateMinorPatch: false,
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    automergeType: "branch",
  },
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  registryAliases: {
    "mirror.gcr.io": "docker.io",
  },
  flux: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml$/"],
  },
  terraform: {
    managerFilePatterns: ["/(^|/)terraform/.+\\.tf$/"],
  },
  ignorePaths: ["**/docker-compose/**"], // Exclude legacy stacks
  customDatasources: {
    "grafana-dashboards": {
      defaultRegistryUrlTemplate: "https://grafana.com/api/dashboards/{{packageName}}",
      format: "json",
      transformTemplates: [
        '{"releases":[{"version": $string(revision)}], "sourceDirectory": name}',
      ],
    },
  },
  customManagers: [
    // Manually match missed items
    // For dependencies with OCI registries, use datasource=docker
    {
      customType: "regex",
      description: "Match annotated dependencies with distinct version",
      managerFilePatterns: [
        "/\\.ya?ml$/",
        "/\\.tf$/",
        "/\\.sh$/",
        "/\\.md$/",
        "/^mise\\.toml$/",
      ],
      matchStrings: [
        "# renovate: datasource=(?<datasource>.+?) depName=(?<depName>.+?)( versioning=(?<versioning>.+?))?( extractVersion=(?<extractVersion>.+?))?( registryUrl=(?<ocimatch>oci:\\/\\/)?(?<registryUrl>.+?))?( gitRef=(?<gitRef>.+?))?\\s.+?(:\\s|\\s?=)(&\\S+)?\\s*[\"']?(?<currentValue>.+?)[\"']?\\s",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}docker{{/if}}",
      packageNameTemplate: "{{depName}}",
      currentValueTemplate: "{{#if gitRef}}{{{gitRef}}}{{else}}{{{currentValue}}}{{/if}}", // Only used if the datasource is gitrefs, the currentValue should refer to the branch
      registryUrlTemplate: "{{#if registryUrl}}{{#if ocimatch}}https://{{/if}}{{{registryUrl}}}{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}",
      extractVersionTemplate: "{{#if extractVersion}}{{{extractVersion}}}{{else}}^v?(?<version>.+)${{/if}}",
    },
    {
      customType: "regex",
      description: "Match annotated container image. Should handle the case when the digest is not specified, therefore on update it is added",
      managerFilePatterns: ["/\\.ya?ml$/"],
      matchStrings: [
        "(?<comment>#\\s*renovate\\s*container:?( versioning=(?<versioning>\\S+))?( extractVersion=(?<extractVersion>\\S+))?\\s*\\n[ \\t]*)(?<prefix>.+?[:=]\\s*)(?<quote>[\"']?)(?<depName>[^:\"\\n'\\s]+):(?<currentValue>[^@\"\\n']+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\"']?",
      ],
      datasourceTemplate: "docker",
      packageNameTemplate: "{{depName}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}docker{{/if}}",
      extractVersionTemplate: "{{#if extractVersion}}{{{extractVersion}}}{{else}}^(?<version>v?.+)${{/if}}",
      // autoReplaceStringTemplate: "{{{comment}}}{{{prefix}}}{{#if quote}}{{{quote}}}{{/if}}{{{depName}}}:{{{newValue}}}{{#if newDigest}}@{{{newDigest}}}{{else}}{{#if currentDigest}}@{{{currentDigest}}}{{/if}}{{/if}}{{#if quote}}{{{quote}}}{{/if}}",
    },
    // Grafana dashboards
    {
      customType: "regex",
      description: "Process Grafana dashboards",
      managerFilePatterns: ["/dashboards?\\.yaml(?:\\.j2)?$/"],
      matchStrings: [
        "dashboards\\/(?<depName>\\d+)\\/revisions\\/(?<currentValue>\\d+)\\/download",
      ],
      datasourceTemplate: "custom.grafana-dashboards",
      versioningTemplate: "regex:^(?<major>\\d+)$",
      autoReplaceStringTemplate: "dashboards/{{depName}}/revisions/{{newValue}}/download",
    },
    {
      customType: "regex",
      description: "Match git refs with only the commit hash as value (and branch ref in comment)",
      managerFilePatterns: [
        "/tachi\/app\/helmrelease\\.ya?ml$/",
        "/tekton-pipelines\/app\/helmrelease\\.ya?ml$/",
      ],
      matchStrings: [
        "# renovate gitref: depName=(?<depName>.+?)( extractVersion=(?<extractVersion>.+?))?( registryUrl=(?<ocimatch>oci:\\/\\/)?(?<registryUrl>.+?))?( gitRef=(?<currentValue>.+?))?\\s.+?(:\\s|\\s?=)(&\\S+)?\\s*[\"']?(?<currentDigest>.+?)[\"']?\\s",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}git-refs{{/if}}",
      packageNameTemplate: "{{depName}}",
      versioningTemplate: "git",
      extractVersionTemplate: "{{#if extractVersion}}{{{extractVersion}}}{{else}}^v?(?<version>.+)${{/if}}",
    },
  ],
  packageRules: [
    // Pin digests
    {
      matchDatasources: ["docker"],
      pinDigests: true,
    },
    // Tachi grouping : some have docker tags and client uses git refs
    {
      matchPackageNames: ["/zkldi\/[tT]achi/"],
      groupName: "Tachi",
      automerge: false,
      commitMessageExtra: "({{#each upgrades}}{{#if currentVersion}}{{#unless @first}}, {{/unless}}{{{currentVersion}}} ➔ {{{newVersion}}}{{/if}}{{/each}})",
      // pinDigests: false,
    },
    // In package rules, we also add non matched packages source url
    // Use opentofu registry as we use it instead of terraform
    {
      matchDatasources: ["terraform-provider"],
      registryUrls: ["https://registry.opentofu.org"],
      group: {
        commitMessageTopic: "{{{groupName}}} terraform provider",
      },
    },
    // Exclude localhost:32000 images
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["^localhost:32000/tachi*"],
      enabled: false,
    },
    // Grouping packages for common PRs
    // * Helm charts and their CRDs
    {
      matchPackageNames: ["/external-secrets/"],
      groupName: "external-secrets",
    },
    {
      matchPackageNames: ["/mariadb-operator/"],
      groupName: "mariadb-operator",
      prBodyNotes: [
        ":warning: Check upgrade notes in https://github.com/mariadb-operator/mariadb-operator/blob/main/docs/releases/UPGRADE_{{newVersion}}.md :warning:",
      ],
    },
    {
      matchPackageNames: ["/traefik/"],
      groupName: "traefik",
    },
    {
      matchPackageNames: ["/victoria-metrics-operator/"],
      groupName: "victoria-metrics-operator",
      changelogUrl: "https://github.com/VictoriaMetrics/helm-charts/blob/master/charts/{{replace 'ghcr.io/victoriametrics/helm-charts/' '' depName}}/CHANGELOG.md",
    },
    {
      matchPackageNames: ["/toolhive-operator/"],
      groupName: "toolhive-operator",
      sourceUrl: "https://github.com/stacklok/toolhive",
    },
    {
      matchPackageNames: ["/velero/"],
      groupName: "velero",
    },
    {
      matchPackageNames: ["/renovate$/"],
      groupName: "renovate",
    },
    {
      description: "llama.cpp uses build-number tags with variant prefix (intel, vulkan, ...). Capture the variant as 'compatibility' so Renovate only proposes upgrades within the same variant stream.",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/ggml-org/llama.cpp"],
      versioning: "regex:^server-(?<compatibility>[a-z]+)-b(?<patch>\\d+)$",
    },
    {
      description: "Similarly to llama.cpp, we match the particular tag",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/anbeeld/beellama.cpp"],
      versioning: "regex:^server-(?<compatibility>[a-z0-9]+)-(?<preview>preview-)?v(?<version>(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+))$",
    },
    // Map sources
    {
      matchPackageNames: ["/papra-hq\/papra/"],
      sourceUrl: "https://github.com/papra-hq/papra",
      changelogUrl: "https://github.com/papra-hq/papra/releases/tag/%40papra%2Fapp%40{{ newVersion }}",
    },
    {
      matchPackageNames: ["/grafana-operator/"],
      sourceUrl: "https://github.com/grafana/grafana-operator",
    },
    {
      matchPackageNames: ["/opentelemetry-kube-stack/"],
      sourceUrl: "https://github.com/open-telemetry/opentelemetry-helm-charts",
      changelogUrl: "https://github.com/open-telemetry/opentelemetry-helm-charts/releases/tag/opentelemetry-kube-stack-{{ newVersion }}",
    },
    {
      matchPackageNames: ["/plugin-barman-cloud/"],
      changelogUrl: "https://github.com/cloudnative-pg/charts/releases/tag/plugin-barman-cloud-v{{ newVersion }}",
    },
    {
      matchPackageNames: ["ghcr.io/cloudnative-pg/charts/cloudnative-pg"],
      changelogUrl: "https://github.com/cloudnative-pg/charts/releases/tag/cloudnative-pg-v{{ newVersion }}",
    },
    {
      matchPackageNames: ["/dragonfly-operator/"],
      sourceUrl: "https://github.com/dragonflydb/dragonfly-operator",
    },
    {
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/goauthentik/helm-charts/authentik"],
      changelogUrl: "https://github.com/goauthentik/helm/compare/authentik-{{ currentVersion }}...authentik-{{ newVersion }}",
    },
    // TrueCharts packages
    // All of them can't be matched with packageNames oci.trueforge.org/truecharts/*, so we're matching the registryUrl
    // {
    //   matchDatasources: ["docker"],
    //   matchJsonata: ["registryUrl = 'https://oci.trueforge.org'"],
    //   sourceUrl: "",
    //   changelogUrl: "https://trueforge.org/truetech/truecharts/charts/stable/{{replace 'oci.trueforge.org/truecharts/' '' depName}}/changelog/",
    // },
    // Terraform providers
    {
      matchPackageNames: ["bpg/proxmox"],
      matchDatasources: ["terraform-provider"],
      groupName: "bpg/proxmox",
      sourceUrl: "https://github.com/bpg/terraform-provider-proxmox",
    },
    // Match all terraform hashicorp official modules
    {
      matchPackageNames: ["hashicorp/*"],
      matchDatasources: ["terraform-provider"],
      groupName: "hashicorp/{{depName}}",
      // NOTE : Templating is not yet supported for sourceUrl, waiting for https://github.com/renovatebot/renovate/issues/35974
      changelogUrl: "https://github.com/hashicorp/terraform-provider-{{depName}}/blob/main/CHANGELOG.md",
    },
    {
      matchPackageNames: ["ansible/ansible"],
      matchDatasources: ["terraform-provider"],
      groupName: "ansible/ansible",
      sourceUrl: "https://github.com/ansible/terraform-provider-ansible",
    },
    {
      matchPackageNames: ["siderolabs/talos"],
      matchDatasources: ["terraform-provider"],
      groupName: "siderolabs/talos",
      sourceUrl: "https://github.com/siderolabs/terraform-provider-talos",
    },
    // Match OS and kubernetes versions
    {
      matchPackageNames: ["siderolabs/talos", "*/siderolabs/installer"],
      groupName: "Talos Linux",
      // Override datasource to take main repository into account to be able to apply minimumReleaseAge
      // overrideDatasource: "github-releases",
      // overridePackageName: "siderolabs/talos",
      commitMessageTopic: "{{groupName}} OS release",
      // Take the first version of the array as currentVersion and newVersion won't resolve
      commitMessageExtra: "({{upgrades.0.currentVersion}} ➔ {{upgrades.0.newVersion}})",
      semanticCommitType: "feat",
      semanticCommitScope: "talos",
      sourceUrl: "https://github.com/siderolabs/talos",
      // minimumReleaseAge: "7 days",
    },
    {
      matchPackageNames: ["/siderolabs\/kubelet/"],
      groupName: "kubernetes",
      semanticCommitType: "feat",
      semanticCommitScope: "talos",
      commitMessageTopic: "{{groupName}}",
      commitMessageExtra: "({{upgrades.0.currentVersion}} ➔ {{upgrades.0.newVersion}})",
    },
    // * retrieve changelogs for non-patch versions of kubernetes
    {
      matchPackageNames: ["/siderolabs\/kubelet/"],
      matchUpdateTypes: ["major", "minor"],
      // sourceUrl: "https://github.com/kubernetes/kubernetes",
      changelogUrl: "https://github.com/kubernetes/kubernetes/blob/{{newVersion}}/CHANGELOG/CHANGELOG-{{newMajor}}.{{newMinor}}.md",
      // minimumReleaseAge: "7 days",
    },
    // Automerge settings
    // Setting from https://docs.renovatebot.com/key-concepts/automerge/#automerge-non-major-updates
    // * Non major updates for development tools
    // Grafana dashboards
    {
      addLabels: ["renovate/grafana-dashboard"],
      automerge: false, // true,
      automergeType: "branch",
      commitMessageExtra: "({{currentVersion}} ➔ {{newVersion}})",
      commitMessageTopic: "dashboard {{sourceDirectory}}",
      ignoreTests: true,
      matchDatasources: ["custom.grafana-dashboards"],
      matchUpdateTypes: ["major", "minor"],
      semanticCommitScope: "grafana-dashboards",
      semanticCommitType: "chore",
    },
    {
      description: "Auto merge patches",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/prowlarr/",
        "/suwayomi/",
        "/sonarr/",
        "/radarr/",
        "/lidarr/",
      ],
      matchUpdateTypes: ["patch"],
      matchCurrentVersion: "!/^0/",
      ignoreTests: true,
      automerge: false, // true,
      automergeType: "pr",
    },
    {
      description: "Auto-merge high-cadence packages weekly",
      matchDatasources: ["docker"],
      automerge: false, // true,
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: [
        "/renovate$/",
        "ghcr.io/mogenius/helm-charts/renovate-operator",
      ],
      schedule: ["before 6am on Sunday"], // So that if there is any problem we can fix it on subday :)
    },
    // // * Non major updates for truecharts
    // {
    //   matchDatasources: ["docker"],
    //   matchJsonata: ["registryUrl = 'https://oci.trueforge.org'"],
    //   matchUpdateTypes: ["minor", "patch"],
    //   matchCurrentVersion: "!/^0/",
    //   ignoreTests: true,
    //   automerge: true,
    //   automergeType: "pr",
    // },
  ],
}
